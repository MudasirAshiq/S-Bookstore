# PostgreSQL connection string (NeonDB)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Server port (Render auto-assigns via PORT env var)
PORT=3000

# Allowed frontend origin for CORS (comma-separated for multiple)
# Example: https://sapienbooks.onrender.com,https://sapienbooks.com
FRONTEND_URL=http://localhost:5173
